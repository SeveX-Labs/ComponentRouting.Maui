<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <_IosTargetFramework Condition="'$(UseAsProjectReference)' == 'true' and '$(OverrideIosSpecificVersion)' != ''">net10.0-ios$(OverrideIosSpecificVersion)</_IosTargetFramework>
		<_IosTargetFramework Condition="'$(_IosTargetFramework)' == ''">net10.0-ios</_IosTargetFramework>

    <_MacCatalystTargetFramework Condition="'$(UseAsProjectReference)' == 'true' and '$(OverrideMacCatalystSpecificVersion)' != ''">net10.0-maccatalyst$(OverrideMacCatalystSpecificVersion)</_MacCatalystTargetFramework>
		<_MacCatalystTargetFramework Condition="'$(_MacCatalystTargetFramework)' == ''">net10.0-maccatalyst</_MacCatalystTargetFramework>

		<_AndroidTargetFramework Condition="'$(UseAsProjectReference)' == 'true' and '$(OverrideAndroidSpecificVersion)' != ''">net10.0-android$(OverrideAndroidSpecificVersion)</_AndroidTargetFramework>
		<_AndroidTargetFramework Condition="'$(UseAsProjectReference)' == 'true' and '$(OverrideAndroidSpecificVersion)' == ''">net10.0-android36.0</_AndroidTargetFramework>
		<_AndroidTargetFramework Condition="'$(_AndroidTargetFramework)' == ''">net10.0-android</_AndroidTargetFramework>

		<TargetFrameworks>$(_IosTargetFramework);$(_AndroidTargetFramework);$(_MacCatalystTargetFramework)</TargetFrameworks>

    <UseMaui>True</UseMaui>
    <Nullable>enable</Nullable>
    <RootNamespace>ComponentRouting.Maui</RootNamespace>
    <AssemblyName>ComponentRouting.Maui</AssemblyName>
    <PackageId>ComponentRouting.Maui</PackageId>
    <Version>5.2.1</Version>
    <PackageVersion>5.2.1</PackageVersion>
    <Title>ComponentRouting.Maui</Title>
    <Description>Component-based routing, navigation, presenters, overlays, snackbars, and dependency-injection helpers for .NET MAUI applications.</Description>
    <Authors>Alessandro Severa</Authors>
    <Company>SeveX Labs</Company>
    <RepositoryUrl>https://github.com/SeveX-Labs/ComponentRouting.Maui</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/SeveX-Labs/ComponentRouting.Maui</PackageProjectUrl>
    <PackageTags>maui;dotnet-maui;routing;navigation;component;components;presenter;router;modal;overlay;snackbar;dependency-injection</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
	<Configurations>Debug;Release;Release_Staging</Configurations>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);AddCoreAssemblyToPackage</TargetsForTfmSpecificBuildOutput>
    <ComponentRoutingCoreAssemblyPath>$(MSBuildThisFileDirectory)..\ComponentRouting.Core\bin\$(Configuration)\net10.0\ComponentRouting.Core.dll</ComponentRoutingCoreAssemblyPath>

    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(_IsPacking)' == 'true'">
    <UseSharedCompilation>false</UseSharedCompilation>
    <BuildInParallel>false</BuildInParallel>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <WarningLevel>4</WarningLevel>
    <NoWarn>1701;1702;IL2121;CS1573;CS1591;CS8618;CS8603;CS8604;</NoWarn>
    <LangVersion>11.0</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <LangVersion>11.0</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release_Staging|AnyCPU' ">
    <DebugType></DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Release_Staging</OutputPath>
    <DefineConstants></DefineConstants>
    <WarningLevel>4</WarningLevel>
    <DocumentationFile></DocumentationFile>
    <IntermediateOutputPath>obj\Release_Staging</IntermediateOutputPath>
    <NoWarn></NoWarn>
    <NoStdLib>false</NoStdLib>
    <Nullable></Nullable>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <ProjectReference Include="..\ComponentRouting.Core\ComponentRouting.Core.csproj" PrivateAssets="all" SetTargetFramework="TargetFramework=net10.0" GlobalPropertiesToRemove="TargetFrameworks" />
    <PackageReference Include="NGettext" Version="0.6.7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="$(MicrosoftExtensionsVersion)" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    <PackageReference Include="PropertyChanged.Fody" Version="4.1.0" PrivateAssets="All" />
    <PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
  </ItemGroup>

  <Target Name="AddCoreAssemblyToPackage" Returns="@(BuildOutputInPackage)">
    <ItemGroup>
      <BuildOutputInPackage
        Include="$(ComponentRoutingCoreAssemblyPath)"
        Condition="Exists('$(ComponentRoutingCoreAssemblyPath)')">
        <FinalOutputPath>$(ComponentRoutingCoreAssemblyPath)</FinalOutputPath>
        <TargetPath>ComponentRouting.Core.dll</TargetPath>
      </BuildOutputInPackage>
    </ItemGroup>
  </Target>
</Project>
