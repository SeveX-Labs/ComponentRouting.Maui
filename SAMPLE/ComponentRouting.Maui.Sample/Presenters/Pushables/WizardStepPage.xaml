<?xml version="1.0" encoding="utf-8" ?>
<abstraction:PushablePresenter xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                               xmlns:abstraction="clr-namespace:ComponentRouting.Maui.Abstraction;assembly=ComponentRouting.Maui"
                               x:Class="ComponentRouting.Maui.Sample.Presenters.Pushables.WizardStepPage">
    <Grid Padding="24">
        <VerticalStackLayout Spacing="12" VerticalOptions="Center">
            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" />
            <Label x:Name="MessageLabel" LineBreakMode="WordWrap" />
            <Button Text="Continue" Clicked="HandleContinueClicked" />
            <Button Text="Back" Clicked="HandleBackTapped" />
        </VerticalStackLayout>
    </Grid>
</abstraction:PushablePresenter>
