<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ComponentRouting.Maui.Sample.Presenters.Modals.OverlayMatrixFullscreenModalPage"
             BackgroundColor="#111827">
    <AbsoluteLayout>
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="24" Spacing="12">
                <Label x:Name="TitleLabel"
                       TextColor="White"
                       FontSize="28"
                       FontAttributes="Bold" />
                <Label x:Name="MessageLabel"
                       TextColor="#CBD5E1"
                       LineBreakMode="WordWrap" />
                <Button Text="Show overlay from fullscreen modal" Clicked="HandleShowOverlayClicked" />
                <Button Text="Show snackbar from fullscreen modal" Clicked="HandleShowSnackbarClicked" />
                <Button Text="Show mutable popup from fullscreen modal" Clicked="HandleShowMutablePopupClicked" />
                <Button Text="Close overlay" Clicked="HandleCloseOverlayClicked" />
                <Button Text="Close fullscreen modal" Clicked="HandleCloseClicked" />
            </VerticalStackLayout>
        </ScrollView>
        <AbsoluteLayout x:Name="OverlayLayer"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All" />
    </AbsoluteLayout>
</ContentPage>
