<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ComponentRouting.Maui.Sample.Presenters.Modals.DetailsPage">
    <Grid Padding="24">
        <VerticalStackLayout Spacing="12" VerticalOptions="Center">
            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" />
            <Label x:Name="MessageLabel" LineBreakMode="WordWrap" />
            <Button Text="Return True" Clicked="HandleTrueClicked" />
            <Button Text="Return False" Clicked="HandleFalseClicked" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
