<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ComponentRouting.Maui.Sample.Presenters.Tabs.HomePage"
             Title="Home">
    <AbsoluteLayout>
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="24" Spacing="12">
                <Label Text="ComponentRouting.Maui sample"
                       FontSize="24"
                       FontAttributes="Bold" />
                <Label Text="This page demonstrates component presentation, mounted overlay lookup, and transient snackbars."
                       FontSize="14" />
                <Button Text="Open Login Page" Clicked="HandleOpenLoginClicked" />
                <Button Text="Open Modal Details" Clicked="HandleOpenDetailsClicked" />
                <Button Text="Start Wizard" Clicked="HandleStartWizardClicked" />
                <Border Padding="12" StrokeThickness="1">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Overlay matrix" FontAttributes="Bold" />
                        <Label Text="Use these actions to compare overlay and snackbar bounds from root, push, modal, and push-inside-modal surfaces."
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                        <Button Text="Show overlay from root" Clicked="HandleShowMatrixRootOverlayClicked" />
                        <Button Text="Show snackbar from root" Clicked="HandleShowMatrixRootSnackbarClicked" />
                        <Button Text="Open push overlay demo" Clicked="HandleOpenPushOverlayDemoClicked" />
                        <Button Text="Open modal overlay demo" Clicked="HandleOpenModalOverlayDemoClicked" />
                    </VerticalStackLayout>
                </Border>
                <Button Text="Show Loading Popup" Clicked="HandleShowLoadingClicked" />
                <Button Text="Hide Loading Popup" Clicked="HandleHideLoadingClicked" />
                <Button Text="Close All Popups" Clicked="HandleCloseAllPopupsClicked" />
                <Button Text="Show Snackbar" Clicked="HandleShowSnackbarClicked" />
                <Button Text="Count Mounted Snackbars" Clicked="HandleCountSnackbarsClicked" />
                <Border Padding="12" StrokeThickness="1">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="ComponentFactory singleton lookup" FontAttributes="Bold" />
                        <Label x:Name="FactoryStatusLabel" Text="Not evaluated" />
                        <Label x:Name="MountedCountsLabel" Text="Mounted overlays: 0; snackbars: 0" />
                        <Label x:Name="LastResultLabel" Text="No result yet" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <AbsoluteLayout x:Name="OverlayLayer"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All" />
    </AbsoluteLayout>
</ContentPage>
