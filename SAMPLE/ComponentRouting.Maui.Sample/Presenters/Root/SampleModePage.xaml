<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ComponentRouting.Maui.Sample.Presenters.Root.SampleModePage"
             Title="Choose sample mode">
    <Grid Padding="24"
          RowDefinitions="*,Auto,*">
        <VerticalStackLayout Grid.Row="1"
                             Spacing="14"
                             VerticalOptions="Center">
            <Label Text="Choose sample mode"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Start the existing tabbed root or the flyout root sample."
                   FontSize="14"
                   HorizontalTextAlignment="Center" />
            <Button Text="Tabbed root"
                    Clicked="HandleTabbedRootClicked" />
            <Button Text="Flyout root"
                    Clicked="HandleFlyoutRootClicked" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
